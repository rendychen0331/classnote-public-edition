<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/overlay_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:clickable="true"
    android:focusable="true">

    <LinearLayout
        android:id="@+id/bottom_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:orientation="horizontal"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingBottom="36dp"
        android:gravity="center_vertical"
        android:clickable="true"
        android:focusable="true">

        <!-- Left circle: 新增提醒 -->
        <FrameLayout
            android:id="@+id/btn_reminder_wrap"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:background="@drawable/bg_circle_surface"
            android:elevation="6dp"
            android:clickable="true"
            android:focusable="true">
            <ImageView
                android:id="@+id/btn_reminder_icon"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_reminder"
                android:tint="#4ECCA3" />
        </FrameLayout>

        <Space
            android:layout_width="8dp"
            android:layout_height="1dp" />

        <!-- Center capsule -->
        <LinearLayout
            android:id="@+id/capsule"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_weight="1"
            android:background="@drawable/bg_capsule_surface"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:elevation="6dp"
            android:clickable="true"
            android:focusable="true">

            <ImageButton
                android:id="@+id/btn_add_attachment"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_quick_add_plus"
                android:padding="12dp"
                android:scaleType="fitCenter" />

            <TextView
                android:id="@+id/hint_text"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="輸入或說些什麼…"
                android:textColor="#88AAA8C3"
                android:textSize="14sp"
                android:clickable="true"
                android:focusable="true" />

            <ImageButton
                android:id="@+id/btn_model"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:scaleType="fitCenter"
                android:padding="8dp"
                android:layout_marginEnd="2dp" />
        </LinearLayout>

        <Space
            android:layout_width="8dp"
            android:layout_height="1dp" />

        <!-- Right circle: 新增筆記 -->
        <FrameLayout
            android:id="@+id/btn_classrecord_wrap"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:background="@drawable/bg_circle_surface"
            android:elevation="6dp"
            android:clickable="true"
            android:focusable="true">
            <ImageView
                android:id="@+id/btn_classrecord_icon"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_class_record"
                android:tint="#4ECCA3" />
        </FrameLayout>

    </LinearLayout>

    <!-- + 附件選擇浮動面板（膠囊左上方） -->
    <LinearLayout
        android:id="@+id/attachment_picker_panel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|start"
        android:layout_marginStart="16dp"
        android:layout_marginBottom="100dp"
        android:background="@drawable/bg_capsule_surface"
        android:elevation="14dp"
        android:orientation="vertical"
        android:paddingHorizontal="4dp"
        android:paddingVertical="6dp"
        android:clickable="true"
        android:focusable="true"
        android:visibility="gone" />

    <!-- AI 模型選擇浮動面板（固定在膠囊上方） -->
    <LinearLayout
        android:id="@+id/model_picker_panel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|center_horizontal"
        android:layout_marginBottom="100dp"
        android:background="@drawable/bg_capsule_surface"
        android:elevation="14dp"
        android:orientation="horizontal"
        android:paddingHorizontal="8dp"
        android:paddingVertical="6dp"
        android:clickable="true"
        android:focusable="true"
        android:visibility="gone" />

    <!-- 新增提醒 mini form -->
    <LinearLayout
        android:id="@+id/form_reminder"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="36dp"
        android:background="@drawable/bg_capsule_surface"
        android:orientation="vertical"
        android:padding="16dp"
        android:elevation="8dp"
        android:clickable="true"
        android:focusable="true"
        android:visibility="gone">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="新增提醒"
            android:textAppearance="?attr/textAppearanceTitleSmall"
            android:textColor="?attr/colorOnSurface"
            android:layout_marginBottom="8dp" />

        <EditText
            android:id="@+id/et_reminder_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="標題（必填）"
            android:imeOptions="actionDone"
            android:inputType="text"
            android:background="@null"
            android:textColor="?attr/colorOnSurface"
            android:textColorHint="?attr/colorOnSurfaceVariant"
            android:padding="4dp"
            android:layout_marginBottom="8dp" />

        <com.google.android.material.chip.ChipGroup
            android:id="@+id/chip_group_date"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:singleSelection="true">

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_today"
                style="@style/Widget.Material3.Chip.Filter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:checked="true"
                android:text="今天" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_tomorrow"
                style="@style/Widget.Material3.Chip.Filter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="明天" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_day_after"
                style="@style/Widget.Material3.Chip.Filter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="後天" />

        </com.google.android.material.chip.ChipGroup>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="end">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_reminder_cancel"
                style="@style/Widget.Material3.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="取消" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_reminder_save"
                style="@style/Widget.Material3.Button.TonalButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="儲存" />

        </LinearLayout>
    </LinearLayout>

    <!-- AI 對話面板 -->
    <LinearLayout
        android:id="@+id/chat_panel"
        android:layout_width="match_parent"
        android:layout_height="400dp"
        android:layout_gravity="bottom"
        android:orientation="vertical"
        android:background="@drawable/bg_chat_panel"
        android:elevation="12dp"
        android:clickable="true"
        android:focusable="true"
        android:visibility="gone">

        <!-- drag handle area (觸控區域 32dp，視覺 bar 置中) -->
        <FrameLayout
            android:id="@+id/drag_handle_area"
            android:layout_width="match_parent"
            android:layout_height="32dp"
            android:clickable="true"
            android:focusable="true">

            <View
                android:layout_width="36dp"
                android:layout_height="4dp"
                android:layout_gravity="center"
                android:background="#44FFFFFF" />

        </FrameLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="4dp"
            android:paddingBottom="4dp">

            <ImageButton
                android:id="@+id/btn_chat_model_panel"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:scaleType="fitCenter"
                android:padding="8dp" />

            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_chat_close"
                style="@style/Widget.Material3.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="✕"
                android:textSize="16sp"
                android:minWidth="0dp"
                android:paddingHorizontal="12dp" />

        </LinearLayout>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_chat"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:clipToPadding="false"
            android:paddingVertical="8dp" />

        <ProgressBar
            android:id="@+id/pb_chat"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:visibility="gone" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="8dp"
            android:paddingBottom="28dp">

            <EditText
                android:id="@+id/et_chat_input"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:hint="輸入訊息…"
                android:inputType="textMultiLine"
                android:maxLines="3"
                android:background="@drawable/bg_capsule_surface"
                android:padding="10dp"
                android:textColor="?attr/colorOnSurface"
                android:textColorHint="?attr/colorOnSurfaceVariant"
                android:layout_marginEnd="8dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_chat_send"
                style="@style/Widget.Material3.Button.TonalButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="送出" />

        </LinearLayout>
    </LinearLayout>

    <!-- 新增上課筆記 mini form -->
    <LinearLayout
        android:id="@+id/form_classrecord"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="36dp"
        android:background="@drawable/bg_capsule_surface"
        android:orientation="vertical"
        android:padding="16dp"
        android:elevation="8dp"
        android:clickable="true"
        android:focusable="true"
        android:visibility="gone">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="新增上課筆記"
            android:textAppearance="?attr/textAppearanceTitleSmall"
            android:textColor="?attr/colorOnSurface"
            android:layout_marginBottom="8dp" />

        <EditText
            android:id="@+id/et_record_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="標題"
            android:inputType="text"
            android:background="@null"
            android:textColor="?attr/colorOnSurface"
            android:textColorHint="?attr/colorOnSurfaceVariant"
            android:padding="4dp"
            android:layout_marginBottom="8dp" />

        <EditText
            android:id="@+id/et_record_note"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="筆記內容"
            android:inputType="textMultiLine"
            android:minLines="2"
            android:maxLines="4"
            android:gravity="top|start"
            android:background="@null"
            android:textColor="?attr/colorOnSurface"
            android:textColorHint="?attr/colorOnSurfaceVariant"
            android:padding="4dp"
            android:layout_marginBottom="8dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="end">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_record_cancel"
                style="@style/Widget.Material3.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="取消" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_record_save"
                style="@style/Widget.Material3.Button.TonalButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="儲存" />

        </LinearLayout>
    </LinearLayout>

</FrameLayout>
