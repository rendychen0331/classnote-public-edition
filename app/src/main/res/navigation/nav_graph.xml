<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/scheduleFragment">

    <!-- ── 課表 ── -->
    <fragment
        android:id="@+id/scheduleFragment"
        android:name="com.rendy.classnote.ui.schedule.ScheduleFragment"
        android:label="@string/nav_schedule"
        tools:layout="@layout/fragment_schedule">
        <action
            android:id="@+id/actionWeekViewFragmentToCourseEditFragment"
            app:destination="@id/courseEditFragment" />
    </fragment>

    <!--
        WeekViewFragment 與 CalendarViewFragment 存在於 ViewPager2 中，
        不是 NavController 的直接目的地，但 WeekViewFragment 仍可呼叫
        findNavController() 取得上層的 NavController 並使用全域 action。
    -->
    <fragment
        android:id="@+id/weekViewFragment"
        android:name="com.rendy.classnote.ui.schedule.WeekViewFragment"
        android:label="@string/tab_week_view"
        tools:layout="@layout/fragment_week_view" />

    <fragment
        android:id="@+id/calendarViewFragment"
        android:name="com.rendy.classnote.ui.schedule.CalendarViewFragment"
        android:label="@string/tab_calendar_view"
        tools:layout="@layout/fragment_calendar_view" />

    <fragment
        android:id="@+id/courseEditFragment"
        android:name="com.rendy.classnote.ui.schedule.CourseEditFragment"
        android:label="@string/add_course"
        tools:layout="@layout/fragment_course_edit">
        <argument
            android:name="courseId"
            app:argType="long"
            android:defaultValue="-1L" />
        <argument
            android:name="dayOfWeek"
            app:argType="integer"
            android:defaultValue="1" />
        <argument
            android:name="period"
            app:argType="integer"
            android:defaultValue="1" />
        <argument
            android:name="semesterId"
            app:argType="string"
            android:defaultValue="" />
    </fragment>

    <!-- ── 提醒 ── -->
    <fragment
        android:id="@+id/reminderListFragment"
        android:name="com.rendy.classnote.ui.reminder.ReminderListFragment"
        android:label="@string/nav_reminders"
        tools:layout="@layout/fragment_reminder_list">
        <action
            android:id="@+id/actionReminderListFragmentToReminderEditFragment"
            app:destination="@id/reminderEditFragment" />
        <action
            android:id="@+id/actionReminderListFragmentToReminderDetailFragment"
            app:destination="@id/reminderDetailFragment" />
    </fragment>

    <fragment
        android:id="@+id/reminderDetailFragment"
        android:name="com.rendy.classnote.ui.reminder.ReminderDetailFragment"
        android:label="@string/nav_reminders"
        tools:layout="@layout/fragment_reminder_detail">
        <argument
            android:name="reminderId"
            app:argType="long"
            android:defaultValue="-1L" />
        <action
            android:id="@+id/actionReminderDetailFragmentToReminderEditFragment"
            app:destination="@id/reminderEditFragment" />
    </fragment>

    <fragment
        android:id="@+id/reminderEditFragment"
        android:name="com.rendy.classnote.ui.reminder.ReminderEditFragment"
        android:label="@string/add_reminder"
        tools:layout="@layout/fragment_reminder_edit">
        <argument
            android:name="reminderId"
            app:argType="long"
            android:defaultValue="-1L" />
    </fragment>

    <!-- ── 天氣 ── -->
    <fragment
        android:id="@+id/weatherFragment"
        android:name="com.rendy.classnote.ui.weather.WeatherFragment"
        android:label="@string/nav_weather"
        tools:layout="@layout/fragment_weather" />

    <!-- ── 設定 ── -->
    <fragment
        android:id="@+id/settingsFragment"
        android:name="com.rendy.classnote.ui.settings.SettingsFragment"
        android:label="@string/nav_settings"
        tools:layout="@layout/fragment_settings">
        <action
            android:id="@+id/actionSettingsToAlarmPerm"
            app:destination="@id/alarmPermFragment"
            app:enterAnim="@anim/slide_in_right"
            app:exitAnim="@anim/slide_out_left"
            app:popEnterAnim="@anim/slide_in_left"
            app:popExitAnim="@anim/slide_out_right" />
        <action
            android:id="@+id/actionSettingsToSync"
            app:destination="@id/syncFragment"
            app:enterAnim="@anim/slide_in_right"
            app:exitAnim="@anim/slide_out_left"
            app:popEnterAnim="@anim/slide_in_left"
            app:popExitAnim="@anim/slide_out_right" />
        <action
            android:id="@+id/actionSettingsToWeatherNotif"
            app:destination="@id/weatherNotifFragment"
            app:enterAnim="@anim/slide_in_right"
            app:exitAnim="@anim/slide_out_left"
            app:popEnterAnim="@anim/slide_in_left"
            app:popExitAnim="@anim/slide_out_right" />
        <action
            android:id="@+id/actionSettingsToAiSettings"
            app:destination="@id/aiSettingsFragment"
            app:enterAnim="@anim/slide_in_right"
            app:exitAnim="@anim/slide_out_left"
            app:popEnterAnim="@anim/slide_in_left"
            app:popExitAnim="@anim/slide_out_right" />
        <action
            android:id="@+id/actionSettingsToApiLog"
            app:destination="@id/apiLogFragment"
            app:enterAnim="@anim/slide_in_right"
            app:exitAnim="@anim/slide_out_left"
            app:popEnterAnim="@anim/slide_in_left"
            app:popExitAnim="@anim/slide_out_right" />
        <action
            android:id="@+id/actionSettingsToPermissions"
            app:destination="@id/permissionsFragment"
            app:enterAnim="@anim/slide_in_right"
            app:exitAnim="@anim/slide_out_left"
            app:popEnterAnim="@anim/slide_in_left"
            app:popExitAnim="@anim/slide_out_right" />
    </fragment>

    <fragment
        android:id="@+id/alarmPermFragment"
        android:name="com.rendy.classnote.ui.settings.AlarmPermSheet"
        android:label="提醒與鬧鐘"
        tools:layout="@layout/sheet_alarm_perm" />

    <fragment
        android:id="@+id/permissionsFragment"
        android:name="com.rendy.classnote.ui.settings.PermissionsSheet"
        android:label="權限設定"
        tools:layout="@layout/sheet_permissions" />

    <fragment
        android:id="@+id/syncFragment"
        android:name="com.rendy.classnote.ui.settings.SyncFragment"
        android:label="同步"
        tools:layout="@layout/fragment_sync">
        <action
            android:id="@+id/actionSyncToBackupSync"
            app:destination="@id/backupSyncFragment"
            app:enterAnim="@anim/slide_in_right"
            app:exitAnim="@anim/slide_out_left"
            app:popEnterAnim="@anim/slide_in_left"
            app:popExitAnim="@anim/slide_out_right" />
        <action
            android:id="@+id/actionSyncToLocalSync"
            app:destination="@id/localSyncFragment"
            app:enterAnim="@anim/slide_in_right"
            app:exitAnim="@anim/slide_out_left"
            app:popEnterAnim="@anim/slide_in_left"
            app:popExitAnim="@anim/slide_out_right" />
    </fragment>

    <fragment
        android:id="@+id/backupSyncFragment"
        android:name="com.rendy.classnote.ui.settings.BackupSyncSheet"
        android:label="雲端服務設定"
        tools:layout="@layout/sheet_backup_sync">
        <action
            android:id="@+id/actionBackupSyncToGoogleSync"
            app:destination="@id/googleSyncFragment"
            app:enterAnim="@anim/slide_in_right"
            app:exitAnim="@anim/slide_out_left"
            app:popEnterAnim="@anim/slide_in_left"
            app:popExitAnim="@anim/slide_out_right" />
        <action
            android:id="@+id/actionBackupSyncToMicrosoftSync"
            app:destination="@id/microsoftSyncFragment"
            app:enterAnim="@anim/slide_in_right"
            app:exitAnim="@anim/slide_out_left"
            app:popEnterAnim="@anim/slide_in_left"
            app:popExitAnim="@anim/slide_out_right" />
    </fragment>

    <fragment
        android:id="@+id/localSyncFragment"
        android:name="com.rendy.classnote.ui.settings.LocalSyncSheet"
        android:label="本地同步設定"
        tools:layout="@layout/sheet_local_sync" />

    <fragment
        android:id="@+id/googleSyncFragment"
        android:name="com.rendy.classnote.ui.settings.GoogleSyncSheet"
        android:label="Google"
        tools:layout="@layout/sheet_google_sync" />

    <fragment
        android:id="@+id/microsoftSyncFragment"
        android:name="com.rendy.classnote.ui.settings.MicrosoftSyncSheet"
        android:label="Microsoft"
        tools:layout="@layout/sheet_microsoft_sync" />

    <fragment
        android:id="@+id/weatherNotifFragment"
        android:name="com.rendy.classnote.ui.settings.WeatherNotifSheet"
        android:label="天氣通知"
        tools:layout="@layout/sheet_weather_notif" />

    <fragment
        android:id="@+id/aiSettingsFragment"
        android:name="com.rendy.classnote.ui.settings.AiSettingsSheet"
        android:label="AI 設定"
        tools:layout="@layout/sheet_ai_settings" />

    <fragment
        android:id="@+id/apiLogFragment"
        android:name="com.rendy.classnote.ui.settings.ApiLogSheet"
        android:label="API 記錄"
        tools:layout="@layout/sheet_api_log" />

    <!-- ── 上課紀錄 ── -->
    <fragment
        android:id="@+id/classRecordListFragment"
        android:name="com.rendy.classnote.ui.classrecord.ClassRecordListFragment"
        android:label="@string/nav_class_record"
        tools:layout="@layout/fragment_class_record_list">
        <action
            android:id="@+id/actionClassRecordListFragmentToClassRecordDetailFragment"
            app:destination="@id/classRecordDetailFragment" />
        <action
            android:id="@+id/actionClassRecordListFragmentToClassRecordSummaryFragment"
            app:destination="@id/classRecordSummaryFragment" />
        <action
            android:id="@+id/actionClassRecordListFragmentToClassRecordEditFragment"
            app:destination="@id/classRecordEditFragment" />
        <action
            android:id="@+id/actionClassRecordListToAudioRecord"
            app:destination="@id/audioRecordFragment" />
        <action
            android:id="@+id/actionClassRecordListToDrawing"
            app:destination="@id/drawingFragment" />
    </fragment>

    <fragment
        android:id="@+id/classRecordDetailFragment"
        android:name="com.rendy.classnote.ui.classrecord.ClassRecordDetailFragment"
        android:label="@string/class_record_add"
        tools:layout="@layout/fragment_class_record_detail">
        <argument
            android:name="recordId"
            app:argType="long" />
        <action
            android:id="@+id/actionClassRecordDetailFragmentToClassRecordEditFragment"
            app:destination="@id/classRecordEditFragment" />
    </fragment>

    <fragment
        android:id="@+id/classRecordSummaryFragment"
        android:name="com.rendy.classnote.ui.classrecord.ClassRecordSummaryFragment"
        android:label="AI 總結"
        tools:layout="@layout/fragment_class_record_summary">
        <argument
            android:name="sessionLabel"
            app:argType="string" />
        <argument
            android:name="summary"
            app:argType="string"
            android:defaultValue="" />
        <argument
            android:name="recordIds"
            app:argType="string"
            android:defaultValue="" />
    </fragment>

    <fragment
        android:id="@+id/classRecordEditFragment"
        android:name="com.rendy.classnote.ui.classrecord.ClassRecordEditFragment"
        android:label="@string/class_record_add"
        tools:layout="@layout/fragment_class_record_edit">
        <argument
            android:name="recordId"
            app:argType="long"
            android:defaultValue="-1L" />
        <argument
            android:name="noteType"
            app:argType="string"
            android:defaultValue="text" />
        <action
            android:id="@+id/actionClassRecordEditToDrawing"
            app:destination="@id/drawingFragment" />
    </fragment>

    <fragment
        android:id="@+id/drawingFragment"
        android:name="com.rendy.classnote.ui.classrecord.DrawingFragment"
        android:label="手寫筆記"
        tools:layout="@layout/fragment_drawing">
        <argument
            android:name="existingPath"
            app:argType="string"
            android:defaultValue="" />
        <argument
            android:name="createRecord"
            app:argType="boolean"
            android:defaultValue="false" />
    </fragment>

    <fragment
        android:id="@+id/audioRecordFragment"
        android:name="com.rendy.classnote.ui.classrecord.AudioRecordFragment"
        android:label="錄音筆記"
        tools:layout="@layout/fragment_audio_record" />

    <!-- ── 公式本 ── -->
    <fragment
        android:id="@+id/formulaListFragment"
        android:name="com.rendy.classnote.ui.formula.FormulaListFragment"
        android:label="@string/nav_formula"
        tools:layout="@layout/fragment_formula_list">
        <action
            android:id="@+id/actionFormulaListFragmentToFormulaEditFragment"
            app:destination="@id/formulaEditFragment" />
    </fragment>

    <fragment
        android:id="@+id/formulaEditFragment"
        android:name="com.rendy.classnote.ui.formula.FormulaEditFragment"
        android:label="@string/formula_edit"
        tools:layout="@layout/fragment_formula_edit">
        <argument
            android:name="formulaId"
            app:argType="long"
            android:defaultValue="-1L" />
    </fragment>

</navigation>
